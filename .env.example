# ── Server ──
PORT=3000
NODE_ENV=development

# ── BREM runtime mode ──
# development | production
BREM_MODE=development
# local | supabase
BREM_BACKEND=local
# true = Supabase 실패 시 localStorage 폴백 (개발 전용)
BREM_ALLOW_LOCAL_FALLBACK=true

# ── Supabase (Dashboard → Project Settings → API) ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# 서버 전용 — Vercel에만 설정, Git/프론트 절대 금지
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_FUNCTIONS_URL=https://YOUR_PROJECT.supabase.co/functions/v1

# ── Admin bootstrap (공개 설정에 loginName/email만 노출) ──
BREM_ADMIN_LOGIN_NAME=관리자
BREM_ADMIN_EMAIL=kim01022680704@gmail.com

# ── 배민Biz 자동 수집 (서버 전용, Git/프론트 절대 금지) ──
# deliverycenter.baemin.com 로그인 후 Network 탭 delivery-status 요청의 Cookie 값
BAEMIN_BIZ_SESSION_COOKIE=
# Playwright 로컬 로그인 테스트용 (선택)
BAEMIN_BIZ_LOGIN_ID=
BAEMIN_BIZ_LOGIN_PASSWORD=
# 로컬 수집 스크립트 capture_date override (선택)
BAEMIN_CAPTURE_DATE=
