# ── Server ──
PORT=3000
NODE_ENV=development

# ── BREM runtime mode ──
# development | production
BREM_MODE=development
# local | supabase
BREM_BACKEND=local
# true = Supabase 실패 시 localStorage 폴백 (개발 전용)
BREM_ALLOW_LOCAL_FALLBACK=true

# ── Supabase (Dashboard → Project Settings → API) ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# 서버 전용 — Vercel에만 설정, Git/프론트 절대 금지
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_FUNCTIONS_URL=https://YOUR_PROJECT.supabase.co/functions/v1

# ── Admin bootstrap (공개 설정에 loginName/email만 노출) ──
BREM_ADMIN_LOGIN_NAME=관리자
BREM_ADMIN_EMAIL=kim01022680704@gmail.com

# ── 배민Biz 자동 수집 (서버 전용, Git/프론트 절대 금지) ──
# Supabase settings(brem_baemin_biz_session)에 저장하는 것을 권장합니다.
# 아래 env는 레거시/비상 fallback 용도입니다.
BAEMIN_BIZ_SESSION_COOKIE=
# 로컬 Playwright 세션 갱신 + 자동 수집 스케줄 서버 포트 (PC에서만 설정, 기본 3939)
# npm run baemin:session-server 실행 시 KST 10:00, 14:00, 17:00, 20:00, 23:30 자동 수집
# Vercel/운영 서버에는 설정하지 마세요 — ERP는 항상 PC localhost:3939 로 연결합니다.
BAEMIN_SESSION_LOCAL_PORT=3939
# PC에서 baemin:session-server 실행 시 필수 — Vercel 배포 보호 우회용 Supabase 직접 저장
# (위 SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY 와 동일 프로젝트 값 사용)
# VERCEL_AUTOMATION_BYPASS_SECRET=  # 선택: brem.kr HTTP API fallback 시 Vercel Dashboard → Deployment Protection → Bypass
# 로컬 수집기가 호출할 운영 URL
BREM_PUBLIC_URL=https://brem.kr
